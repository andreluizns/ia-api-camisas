# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ─── Dependências e build ───────────────────────────────────

/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
/.next/
/out/
/build
*.tsbuildinfo
next-env.d.ts

# ─── Gerado automaticamente ─────────────────────────────────

/src/generated/prisma

# ─── Secrets e variáveis de ambiente ────────────────────────

.env
.env.*
.env.local
.env.development
.env.production
.env.test

# ─── Chaves e certificados ──────────────────────────────────

*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
*.der
id_rsa
id_ed25519
*.ppk

# ─── Arquivos de credenciais comuns ─────────────────────────

credentials.json
service-account.json
secrets.json
secrets.yaml
secrets.yml
*secret*
*credential*
*password*
auth.json
firebase-adminsdk*.json
gcloud-credentials.json
aws-credentials
.aws/

# ─── Ferramentas e IDE ──────────────────────────────────────

.DS_Store
.vercel
.claude/

# ─── Logs e debug ───────────────────────────────────────────

npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
/coverage

tmp/

# Documentação interna
docs/
