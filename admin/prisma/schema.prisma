generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Better Auth tables ──────────────────────────────────────────────────────
model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean
  image         String?
  role          String    @default("user")
  banned        Boolean?
  banReason     String?
  banExpires    DateTime?
  createdAt     DateTime
  updatedAt     DateTime
  sessions      Session[]
  accounts      Account[]
  permission    UserPermission?

  @@map("admin_users")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("admin_sessions")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@map("admin_accounts")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("admin_verifications")
}

// ── Domínio ─────────────────────────────────────────────────────────────────
model Camisa {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  club      String   @db.VarChar(120)
  brand     String   @db.VarChar(80)
  model     String   @db.VarChar(120)
  year      Int
  price     Decimal  @db.Decimal(12, 2)
  imageUrl  String?  @map("image_url") @db.VarChar(2048)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz

  @@map("camisas")
}

// ── Chat ─────────────────────────────────────────────────────────────────────
model ChatSession {
  id        String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String        @db.VarChar(200)
  city      String        @db.VarChar(200)
  createdAt DateTime      @default(now()) @db.Timestamptz
  messages  ChatMessage[]

  // Índice em city: o relatório usa groupBy("city") para contar cidades únicas.
  @@index([city])
  @@map("chat_sessions")
}

model ChatMessage {
  id        String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionId String      @db.Uuid
  role      String      @db.VarChar(10)   // "user" | "assistant"
  content   String      @db.Text
  createdAt DateTime    @default(now()) @db.Timestamptz
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("chat_messages")
}

// ── RBAC ─────────────────────────────────────────────────────────────────────
model UserPermission {
  id               String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String  @unique
  user             User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  canCreateCamisa  Boolean @default(false)
  canEditCamisa    Boolean @default(false)
  canDeleteCamisa  Boolean @default(false)
  canManageUsers   Boolean @default(false)

  @@map("user_permissions")
}
